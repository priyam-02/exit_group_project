# M&A Research Pipeline - Environment Variables
# Copy this file to .env and fill in your API keys

# Google Places API Key (for company discovery)
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable: Places API, Places API (New)
GOOGLE_PLACES_API_KEY=

# SerpAPI Key (for Google search results)
# Get one at: https://serpapi.com/
SERPAPI_KEY=

# Database path (default: data/companies.db)
DB_PATH=data/companies.db

# LLM API Key (optional - for advanced classification)
# LLM_API_KEY=
# LLM_PROVIDER=anthropic
